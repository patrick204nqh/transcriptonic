{
  "manifest_version": 3,
  "name": "Meet Transcripts",
  "version": "1.0.0",
  "description": "Meet Transcripts — Google Meet transcript capture. Private, local, no telemetry.",
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "optional_permissions": [
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  }
}